{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mojimaru",
  "version": "0.1.0",
  "identifier": "com.mojimaru.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Mojimaru 文字丸",
        "width": 1180,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Manga translator",
    "longDescription": "Mojimaru — detect speech bubbles in manga, OCR the CJK text, translate it, and overlay the translation back onto the page.",
    "externalBin": [
      "binaries/mojimaru"
    ]
  },
  "plugins": {}
}
